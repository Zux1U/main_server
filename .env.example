# mc-bot-colony local defaults
# Note: app reads process env directly (no dotenv loader).

MCB_HOST=127.0.0.1
MCB_PORT=25566
MCB_AUTH=offline

MCB_RCON_ENABLED=true
MCB_RCON_HOST=127.0.0.1
MCB_RCON_PORT=25575
MCB_RCON_PASSWORD=arena-local-pass

MCB_BOT_COUNT=50
MCB_BOT_MAX_COUNT=1000
MCB_BOT_SAFE_SCALE_LIMIT=120
MCB_BOT_START_ON_BOOT=false

MCB_ARENA_ENABLED=true
MCB_ARENA_SERVER_CONTROL_ENABLED=true
MCB_ARENA_LOGIN_RECOVERY_ENABLED=true

MCB_WEB_ENABLED=true
MCB_WEB_HOST=127.0.0.1
MCB_WEB_PORT=3210
